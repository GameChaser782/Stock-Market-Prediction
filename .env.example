# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose one: ollama | google | anthropic | openai
AGENT_PROVIDER=ollama
AGENT_MODEL=qwen3.5
# AGENT_TEMPERATURE=0.7

# ── API Keys (only set the one you use) ───────────────────────────────────────
# GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Ollama (if using local models) ────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434

# ── Optional: better news search ─────────────────────────────────────────────
# TAVILY_API_KEY=

# ── Optional: additional market data ─────────────────────────────────────────
# ALPHA_VANTAGE_KEY=
# FINNHUB_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
# AGENT_SERVER_HOST=0.0.0.0
# AGENT_SERVER_PORT=8000
